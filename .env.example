# ChurnGuard - Environment Variables
# Copy this to .env and fill in your values

# App
SECRET_KEY=change-me-to-a-random-string
APP_URL=http://localhost:8000

# Database
DATABASE_URL=sqlite:///./churnguard.db

# Stripe (for charging our customers)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect (for our customers to connect THEIR Stripe)
STRIPE_CONNECT_CLIENT_ID=ca_...

# SendGrid (for dunning emails - our customers' emails)
SENDGRID_API_KEY=SG...

# Twilio (for SMS dunning)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Admin
ADMIN_EMAIL=admin@churnguard.io
